# SkillForge - example configuration
#
# Copy and fill in:  cp .env.example .env
#
# Settings are loaded from the environment / .env via pydantic-settings.
#
# Legend:  [REQUIRED] must be set · [optional] default applies when omitted.


# --- Auth (prefix AUTH__) -----------------------------------------------------
# OAuth2 client credentials + JWT.

# [REQUIRED] Symmetric key used to sign the JWTs. Any random secret string,
#            e.g.:  openssl rand -hex 32
AUTH__SECRET_KEY=change-me-to-a-random-secret

# [optional] JWT signing algorithm.  Default: HS256
#            Possible values (symmetric): HS256 | HS384 | HS512
AUTH__ALGORITHM=HS256

# [optional] JWT "iss" claim.  Default: skillforge
AUTH__ISSUER=skillforge

# [optional] JWT "aud" claim.  Default: skillforge-api
AUTH__AUDIENCE=skillforge-api

# [optional] Access token lifetime in minutes.  Default: 15
AUTH__ACCESS_TOKEN_EXPIRE_MINUTES=15


# --- Database (prefix DB__) -----------------------------------------------------
# Postgres via the async driver asyncpg.

# [REQUIRED] Connection URL used by the app (the pooled Neon connection in prod).
#            Format: postgresql+asyncpg://USER:PASS@HOST:PORT/DBNAME
DB__URL=postgresql+asyncpg://skillforge:skillforge@localhost:5432/skillforge

# [optional] Direct, unpooled URL used only for migrations (Alembic).  Default:
#            falls back to DB__URL. Required in prod because a PgBouncer pooler
#            (Neon "-pooler") breaks advisory locks + CONCURRENTLY. See ADR 0002.
#DB__MIGRATION_URL=postgresql+asyncpg://skillforge:skillforge@db.direct-host:5432/skillforge


# --- Logging (prefix LOGGING__) -----------------------------------------------------
# All optional. Defaults are suited for local development.

# [optional] Application name shown in logs.  Default: skillforge
LOGGING__APP_NAME=skillforge

# [optional] Log level.  Default: INFO
#            Possible values: NOTSET | DEBUG | INFO | WARNING | ERROR | CRITICAL
LOGGING__LEVEL=INFO

# [optional] Output format.  Default: console
#            Possible values: console (human-readable) | json (structured, for prod)
LOGGING__FORMAT=console

# [optional] Show local variables in console tracebacks.  Default: false
#            Enable only for local debugging (may leak secrets).
LOGGING__EXCEPTION_SHOW_LOCALS=false

# [optional] Enable rotating JSONL file logging.  Default: false
LOGGING__FILE_ENABLED=false

# [optional] Log file path.  Default: logs/{app_name}.jsonl
#LOGGING__FILE_PATH=logs/skillforge.jsonl

# [optional] Max bytes per log file before rotation.  Default: 10485760 (10 MB)
LOGGING__FILE_MAX_BYTES=10485760

# [optional] Number of rotated files to keep.  Default: 5
LOGGING__FILE_BACKUP_COUNT=5
